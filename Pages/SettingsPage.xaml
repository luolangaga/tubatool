<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <StackPanel
                MaxWidth="820"
                Padding="28,18,28,36"
                Spacing="20">

                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="30"
                        FontWeight="SemiBold"
                        Text="设置" />
                    <TextBlock
                        Opacity="0.72"
                        Text="关于本应用、作者及开源引用。" />
                </StackPanel>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="72"
                            Height="72"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="16">
                            <FontIcon
                                FontSize="36"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE8B7;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="图吧工具箱" />
                            <TextBlock Opacity="0.68" Text="基于 WinUI 3 构建的 PC 硬件工具集合" />
                            <TextBlock
                                x:Name="VersionText"
                                Opacity="0.52"
                                FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="外观" />

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="44"
                                Height="44"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <FontIcon FontSize="22" Glyph="&#xE790;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="应用主题" />
                                <TextBlock Opacity="0.68" Text="选择浅色、深色或跟随系统" />
                            </StackPanel>

                            <ComboBox
                                x:Name="ThemeComboBox"
                                Grid.Column="2"
                                MinWidth="120"
                                SelectionChanged="ThemeComboBox_SelectionChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="作者" />

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <PersonPicture
                                x:Name="AuthorAvatar"
                                Width="56"
                                Height="56" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="哈基毅" />
                                <TextBlock
                                    Opacity="0.68"
                                    Text="开发者 / Designer" />
                            </StackPanel>

                            <HyperlinkButton
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Padding="12,6"
                                NavigateUri="https://github.com/luolangaga">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8F1;" />
                                    <TextBlock Text="GitHub" />
                                </StackPanel>
                            </HyperlinkButton>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="工具来源" />

                        <Border
                            Grid.Row="1"
                            Padding="16"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="48"
                                    Height="48"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10">
                                    <FontIcon
                                        FontSize="24"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Glyph="&#xE90F;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="图吧工具箱" />
                                    <TextBlock
                                        x:Name="ToolSourceText"
                                        Opacity="0.72"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="开源引用" />

                        <StackPanel Grid.Row="1" Spacing="8">
                            <Border
                                Padding="14,12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="Windows App SDK (WinUI 3)" />
                                        <TextBlock
                                            Opacity="0.62"
                                            FontSize="12"
                                            Text="Microsoft.WindowsAppSDK" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        NavigateUri="https://github.com/microsoft/WindowsAppSDK"
                                        Content="GitHub" />
                                </Grid>
                            </Border>

                            <Border
                                Padding="14,12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="Win2D" />
                                        <TextBlock
                                            Opacity="0.62"
                                            FontSize="12"
                                            Text="Microsoft.Graphics.Win2D" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        NavigateUri="https://github.com/microsoft/Win2D"
                                        Content="GitHub" />
                                </Grid>
                            </Border>

                            <Border
                                Padding="14,12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="System.Drawing.Common" />
                                        <TextBlock
                                            Opacity="0.62"
                                            FontSize="12"
                                            Text="图标提取与图像处理" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        NavigateUri="https://learn.microsoft.com/dotnet/core/compatibility/core-libraries/6.0/system-drawing-common-windows-only"
                                        Content="Docs" />
                                </Grid>
                            </Border>

                            <Border
                                Padding="14,12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="System.Management" />
                                        <TextBlock
                                            Opacity="0.62"
                                            FontSize="12"
                                            Text="WMI 硬件信息查询" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        NavigateUri="https://learn.microsoft.com/dotnet/api/system.management"
                                        Content="Docs" />
                                </Grid>
                            </Border>

                            <Border
                                Padding="14,12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="Microsoft.Windows.SDK.BuildTools" />
                                        <TextBlock
                                            Opacity="0.62"
                                            FontSize="12"
                                            Text="Windows SDK 构建工具" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        NavigateUri="https://www.nuget.org/packages/Microsoft.Windows.SDK.BuildTools"
                                        Content="NuGet" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="开发者" />

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="44"
                                Height="44"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <FontIcon FontSize="22" Glyph="&#xE90F;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="测试异常页面" />
                                <TextBlock Opacity="0.68" Text="手动抛出一个未处理异常，用于验证全局错误页面。" />
                            </StackPanel>

                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Padding="14,6"
                                Click="ThrowErrorButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE783;" />
                                    <TextBlock Text="抛出异常" />
                                </StackPanel>
      </Button>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

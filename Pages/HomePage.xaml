<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:FavGlyphConverter x:Key="FavGlyphConverter" />
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <local:NullToVisibilityConverter x:Key="NullToCollapse" />
        <local:HasAlternatesToVisibilityConverter x:Key="HasAlternatesToVis" />
        <local:NoAlternatesToVisibilityConverter x:Key="NoAlternatesToVis" />
        <local:ArchOptionsCountConverter x:Key="ArchOptionsCountConverter" />
        <local:ZeroToIndeterminateConverter x:Key="ZeroIsIndeterminate" />
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="TagRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Indeterminate" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolCardStyle" TargetType="GridViewItem">
            <Setter Property="Width" Value="270" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="CompactCardStyle" TargetType="GridViewItem">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="MaxWidth" Value="120" />
            <Setter Property="MinHeight" Value="90" />
            <Setter Property="Margin" Value="4,4,4,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="28,18,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image
            x:Name="BackgroundImg"
            Stretch="UniformToFill"
            Opacity="0.15"
            Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />

        <Grid ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        x:Name="CategoryTitle"
                        FontSize="30"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="ToolCountText"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,4"
                        FontSize="14"
                        Opacity="0.6" />
                </StackPanel>
                <TextBlock
                    x:Name="CategorySubtitle"
                    Opacity="0.72" />
            </StackPanel>

            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                MinWidth="260"
                PlaceholderText="搜索工具"
                QueryIcon="Find"
                TextChanged="SearchBox_TextChanged" />
        </Grid>

        <ScrollViewer
            x:Name="TagBarScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            Visibility="Collapsed">
            <StackPanel x:Name="TagBarPanel" Orientation="Horizontal" Spacing="6" />
        </ScrollViewer>

        <Grid Grid.Row="2">
            <GridView
                x:Name="ToolsGrid"
                IsItemClickEnabled="True"
                ItemClick="ToolsGrid_ItemClick"
                ItemContainerStyle="{StaticResource ToolCardStyle}"
                SelectionMode="None"
                Visibility="Collapsed">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                VerticalAlignment="Stretch">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="48"
                                            Height="48"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="8">
                                            <Grid>
                                                <Image
                                                    Width="32"
                                                    Height="32"
                                                    Source="{Binding IconPath}"
                                                    Stretch="Uniform"
                                                    Visibility="{Binding IconPath, Converter={StaticResource NullToCollapse}}" />
                                                <FontIcon
                                                    FontSize="24"
                                                    Glyph="{Binding IconGlyph}"
                                                    Visibility="{Binding IconGlyph, Converter={StaticResource NullToCollapse}}" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.64"
                                                Text="{Binding Category}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            VerticalAlignment="Top"
                                            Click="FavoriteButton_Click"
                                            ToolTipService.ToolTip="收藏">
                                            <FontIcon
                                                FontSize="14"
                                                Glyph="{Binding IsFavorite, Converter={StaticResource FavGlyphConverter}}" />
                                        </Button>
                                    </Grid>

                                    <TextBlock
                                        Grid.Row="1"
                                        MaxLines="2"
                                        Opacity="0.72"
                                        Text="{Binding Description}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Grid.Row="2"
                                        FontSize="10"
                                        Opacity="0.68"
                                        Text="{Binding TagsText}"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="{Binding TagsText, Converter={StaticResource NullToCollapse}}" />

                                    <Grid Grid.Row="3" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            HorizontalAlignment="Left"
                                            Padding="8,3"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{Binding Extension}" />
                                        </Border>
                                        <ComboBox
                                            Grid.Column="1"
                                            MinWidth="64"
                                            Padding="6,2"
                                            FontSize="12"
                                            ItemsSource="{Binding ArchOptions}"
                                            SelectedItem="{Binding SelectedArch, Mode=TwoWay}"
                                            Visibility="{Binding ArchOptions.Count, Converter={StaticResource ArchOptionsCountConverter}}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="12" Text="{Binding DisplayText}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Padding="6,4"
                                            Click="SendToDesktopButton_Click"
                                            ToolTipService.ToolTip="发送到桌面快捷方式">
                                            <FontIcon FontSize="12" Glyph="&#xE8BD;" />
                                        </Button>
                                        <Button
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            Padding="10,4"
                                            Click="RunAsAdminButton_Click"
                                            ToolTipService.ToolTip="以管理员身份运行"
                                            Visibility="{Binding NeedsDownload, Converter={StaticResource InvertBoolToVis}}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontSize="12" Glyph="&#xE7EF;" />
                                                <TextBlock FontSize="12" Text="管理员" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Padding="10,4"
                                            Click="LaunchButton_Click"
                                            Content="{Binding LaunchButtonText}"
                                            IsEnabled="{Binding CanLaunch}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

            <GridView
                x:Name="CompactGrid"
                IsItemClickEnabled="True"
                ItemClick="CompactGrid_ItemClick"
                ItemContainerStyle="{StaticResource CompactCardStyle}"
                SelectionMode="None"
                Visibility="Collapsed">
                    <GridView.Resources>
                        <MenuFlyout x:Key="CompactItemFlyout">
                            <MenuFlyoutItem Text="发送到桌面快捷方式" Click="CompactMenu_SendToDesktop" Icon="Link" />
                            <MenuFlyoutItem Text="以管理员身份运行" Click="CompactMenu_RunAsAdmin" Icon="Admin" />
                        </MenuFlyout>
                    </GridView.Resources>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="8,10,8,6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                RightTapped="CompactItem_RightTapped"
                                ToolTipService.ToolTip="{Binding Description}">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <Border
                                        Width="48"
                                        Height="48"
                                        HorizontalAlignment="Center"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="10">
                                        <Grid>
                                            <Image
                                                Width="36"
                                                Height="36"
                                                Source="{Binding IconPath}"
                                                Stretch="Uniform"
                                                Visibility="{Binding IconPath, Converter={StaticResource NullToCollapse}}" />
                                            <FontIcon
                                                FontSize="24"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Glyph="{Binding IconGlyph}"
                                                Visibility="{Binding IconGlyph, Converter={StaticResource NullToCollapse}}" />
                                        </Grid>
                                    </Border>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        MaxLines="2"
                                        Text="{Binding Name}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap"
                                        Width="84" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

            <StackPanel
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="Collapsed">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Glyph="&#xE721;"
                    Opacity="0.3" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    Opacity="0.52"
                    Text="没有找到匹配的工具" />
                <TextBlock
                    x:Name="EmptyStateText"
                    HorizontalAlignment="Center"
                    Opacity="0.42"
                    Text="" />
            </StackPanel>

            <TeachingTip
                x:Name="ToolDetailTip"
                CloseButtonContent="关闭"
                PreferredPlacement="Right">
                <StackPanel MaxWidth="420" Spacing="8">
                    <TextBlock x:Name="DetailDescriptionText" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPublisherText" Opacity="0.72" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailVersionText" Opacity="0.72" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPathText" Opacity="0.72" TextWrapping="Wrap" />
                </StackPanel>
            </TeachingTip>

            <InfoBar
                x:Name="StatusBar"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsOpen="False"
                IsClosable="True" />
        </Grid>
    </Grid>
</Page>